# Iron Bolt Configuration Example
# Copy this to .env and fill in your actual keys

APP_NAME="Iron Bolt"
APP_VERSION="AR1"
APP_ENV=development # development, staging, production, test
LOG_LEVEL=INFO

# Provider API Keys
# Get your keys from:
# OpenAI: https://platform.openai.com/
# Gemini: https://aistudio.google.com/
# Groq:   https://console.groq.com/
# Tavily: https://tavily.com/
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# Default Provider Settings
# To use OpenAI: ACTIVE_PROVIDER=openai, MODEL_NAME=gpt-5.5
# To use Gemini: ACTIVE_PROVIDER=gemini, MODEL_NAME=gemini-2.0-flash
# To use Groq:   ACTIVE_PROVIDER=groq, MODEL_NAME=openai/gpt-oss-120b

ACTIVE_PROVIDER=groq
MODEL_NAME=openai/gpt-oss120b
PROVIDER_TIMEOUT_SECONDS=30.0
TEMPERATURE=0.7

# Database Configuration
DB_BACKEND=sqlite
SQLITE_PATH=./database/mahir.db
POSTGRES_DSN=

# Memory Configuration
MEMORY_SHORT_TERM_TTL=3600
MEMORY_LONG_TERM_ENABLED=false
MEMORY_RETENTION_DAYS=30

# MCP Configuration
MCP_ENABLED=false
MCP_SERVER_URLS=
